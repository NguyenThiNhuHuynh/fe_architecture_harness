<mxfile host="app.diagrams.net" version="24.0.0"><diagram name="FrontForge - Narrative Flow" id="frontforge-narrative-flow"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1150" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="legend_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="1580" y="20" width="300" height="230" as="geometry" /></mxCell><mxCell id="legend_title" value="Chú giải" style="text;html=1;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1600" y="30" width="200" height="20" as="geometry" /></mxCell><mxCell id="lg_auto_sw" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEEFB;strokeColor=#6C9BD1;" vertex="1" parent="1"><mxGeometry x="1600" y="58" width="26" height="20" as="geometry" /></mxCell><mxCell id="lg_auto_lbl" value="Automated — không cần AI phán đoán" style="text;html=1;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1636" y="55" width="230" height="26" as="geometry" /></mxCell><mxCell id="lg_agent_sw" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECC8;strokeColor=#D9A62E;" vertex="1" parent="1"><mxGeometry x="1600" y="90" width="26" height="20" as="geometry" /></mxCell><mxCell id="lg_agent_lbl" value="AI Agent — tự suy luận &amp; quyết định" style="text;html=1;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1636" y="87" width="230" height="26" as="geometry" /></mxCell><mxCell id="lg_mem_sw" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5E9C9;strokeColor=#B08900;" vertex="1" parent="1"><mxGeometry x="1600" y="122" width="26" height="20" as="geometry" /></mxCell><mxCell id="lg_mem_lbl" value="Memory — những gì hệ thống nhớ lại" style="text;html=1;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1636" y="119" width="230" height="26" as="geometry" /></mxCell><mxCell id="lg_guard_sw" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBE2E2;strokeColor=#C94D4D;dashed=1;" vertex="1" parent="1"><mxGeometry x="1600" y="154" width="26" height="20" as="geometry" /></mxCell><mxCell id="lg_guard_lbl" value="Guardrail — giới hạn an toàn cố định" style="text;html=1;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1636" y="151" width="230" height="26" as="geometry" /></mxCell><mxCell id="lg_hitl_sw" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6C9D9;strokeColor=#C94D7A;" vertex="1" parent="1"><mxGeometry x="1600" y="186" width="26" height="20" as="geometry" /></mxCell><mxCell id="lg_hitl_lbl" value="Human-in-the-loop checkpoint" style="text;html=1;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1636" y="183" width="230" height="26" as="geometry" /></mxCell><mxCell id="lg_loop_note" value="↻ Self-fix loop (tối đa 3 lần — MAX_HUMAN_REVISIONS)" style="text;html=1;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="1600" y="222" width="260" height="30" as="geometry" /></mxCell><mxCell id="input" value="Yêu cầu của bạn&#10;(vd: &quot;Xây nền tảng học trực tuyến —&#10;giảng viên tạo khoá học, học viên&#10;theo dõi tiến độ và tải chứng chỉ&quot;)" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fontSize=12;align=center;valign=middle;fillColor=#F2F2F2;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="40" y="190" width="240" height="110" as="geometry" /></mxCell><mxCell id="mem_box" value="MEMORY&#10;- Nhớ project này trông như thế nào&#10;  (state.json + outputs/*.json)&#10;- Lần chạy sau đọc lại đúng chỗ đã&#10;  dừng, không lặp lại việc đã xong" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#F5E9C9;strokeColor=#B08900;" vertex="1" parent="1"><mxGeometry x="720" y="30" width="380" height="110" as="geometry" /></mxCell><mxCell id="guard_box" value="GUARDRAIL&#10;- --json-schema ép đúng cấu trúc, DAG cố&#10;  định thứ tự stage, RunLock chặn 2 tiến&#10;  trình cùng ghi state.json&#10;- Tối đa 3 lần thử/stage rồi FAILED,&#10;  không lặp vô hạn&#10;- safe_join chặn ghi file ngoài generated/" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#FBE2E2;strokeColor=#C94D4D;dashed=1;" vertex="1" parent="1"><mxGeometry x="1140" y="30" width="400" height="130" as="geometry" /></mxCell><mxCell id="step1" value="BƯỚC 1 — HIỂU YÊU CẦU&#10;(clarification · AI Agent)&#10;&#10;• Đọc yêu cầu thô, xác định loại project&#10;• Xác định module chính, tech preference&#10;  đã nêu (hoặc ngầm định)&#10;• Thiếu gì thì tự đưa giả định — ghi vào&#10;  &quot;assumptions&quot;, không hỏi lại giữa chừng" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#FDECC8;strokeColor=#D9A62E;" vertex="1" parent="1"><mxGeometry x="320" y="170" width="340" height="150" as="geometry" /></mxCell><mxCell id="step2" value="BƯỚC 2 — AI LẬP KẾ HOẠCH TOÀN BỘ&#10;(requirement → business_analysis/design_system/&#10;design_analysis → information_architecture →&#10;frontend_architecture → page_planning →&#10;component_planning · AI Agent, nhiều lời gọi)&#10;&#10;• Định nghĩa role, entity, feature&#10;• Định nghĩa màu/typography — ưu tiên đúng&#10;  giá trị Figma nếu bạn có đưa link&#10;• Định nghĩa sitemap, kiến trúc FE, danh&#10;  sách trang và component cụ thể&#10;• Mỗi bước đọc lại output bước trước, không&#10;  tự bịa lại từ đầu" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#FDECC8;strokeColor=#D9A62E;" vertex="1" parent="1"><mxGeometry x="720" y="170" width="460" height="210" as="geometry" /></mxCell><mxCell id="step3" value="BƯỚC 3 — SINH CODE THẬT&#10;(codegen · AI Agent + Automated)&#10;&#10;• AI: sinh nội dung từng file theo đúng&#10;  component/page plan đã có&#10;• Automated: safe_join kiểm tra path,&#10;  FilesystemTool ghi file thật vào generated/&#10;  — model không bao giờ tự ghi file" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#FDECC8;strokeColor=#D9A62E;" vertex="1" parent="1"><mxGeometry x="1240" y="170" width="340" height="150" as="geometry" /></mxCell><mxCell id="step4" value="BƯỚC 4 — TỰ KIỂM TRA NHIỀU LỚP TRƯỚC KHI GIAO" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;align=left;valign=top;spacing=8;fillColor=#DCEEFB;strokeColor=#6C9BD1;" vertex="1" parent="1"><mxGeometry x="320" y="420" width="1260" height="40" as="geometry" /></mxCell><mxCell id="c1" value="Đúng JSON&#10;schema" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#DCEEFB;strokeColor=#6C9BD1;align=center;valign=middle;" vertex="1" parent="1"><mxGeometry x="340" y="475" width="180" height="90" as="geometry" /></mxCell><mxCell id="c2" value="Chạy tsc&#10;(type check)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#DCEEFB;strokeColor=#6C9BD1;align=center;valign=middle;" vertex="1" parent="1"><mxGeometry x="535" y="475" width="180" height="90" as="geometry" /></mxCell><mxCell id="c3" value="Chạy eslint" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#DCEEFB;strokeColor=#6C9BD1;align=center;valign=middle;" vertex="1" parent="1"><mxGeometry x="730" y="475" width="180" height="90" as="geometry" /></mxCell><mxCell id="c4" value="Chạy npm&#10;run build" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#DCEEFB;strokeColor=#6C9BD1;align=center;valign=middle;" vertex="1" parent="1"><mxGeometry x="925" y="475" width="180" height="90" as="geometry" /></mxCell><mxCell id="c5" value="preview: so khớp&#10;với page/component&#10;plan (AI Agent)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#FDECC8;strokeColor=#D9A62E;align=center;valign=middle;" vertex="1" parent="1"><mxGeometry x="1120" y="475" width="180" height="90" as="geometry" /></mxCell><mxCell id="c6" value="quality_review:&#10;chấm điểm, liệt kê&#10;issue (AI Agent)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#FDECC8;strokeColor=#D9A62E;align=center;valign=middle;" vertex="1" parent="1"><mxGeometry x="1315" y="475" width="180" height="90" as="geometry" /></mxCell><mxCell id="step4_note" value="Nếu 1 lớp fail, hệ thống biết chính xác sai ở đâu để sửa — không đoán mò." style="text;html=1;fontSize=11;fontStyle=2;align=left;" vertex="1" parent="1"><mxGeometry x="340" y="575" width="1200" height="24" as="geometry" /></mxCell><mxCell id="finished" value="Pipeline hoàn tất&#10;Code thật nằm trong generated/,&#10;kèm báo cáo quality_review.json" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fontSize=12;align=center;valign=middle;fillColor=#D9EAD3;strokeColor=#6AA84F;" vertex="1" parent="1"><mxGeometry x="1660" y="475" width="220" height="100" as="geometry" /></mxCell><mxCell id="hitl1" value="HUMAN-IN-THE-LOOP CHECKPOINT 1&#10;&#10;Sau MỌI stage trừ quality_review, pipeline dừng&#10;lại và hỏi bạn:&#10;&quot;Xem output của stage này — tiếp tục sang stage&#10;tiếp theo?&quot;&#10;&#10;Nếu bạn chọn Không, AI không tự đoán ý bạn —&#10;nó hỏi tiếp: dừng hẳn để bạn tự sửa file, hay&#10;nhập feedback bằng lời để nó tự sửa đúng stage&#10;đó và chạy lại ngay." style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#F6C9D9;strokeColor=#C94D7A;" vertex="1" parent="1"><mxGeometry x="40" y="420" width="340" height="230" as="geometry" /></mxCell><mxCell id="hitl2" value="HUMAN-IN-THE-LOOP CHECKPOINT 2&#10;&#10;Sau khi quality_review liệt kê issue (blocker/&#10;major/minor), pipeline dừng lại và hỏi:&#10;&quot;Tự động chạy sửa lỗi codegen với các issue&#10;này không?&quot;&#10;&#10;Tối đa 3 lần — sau đó tự ngừng hỏi, để tránh&#10;lặp vô hạn nếu vấn đề thật ra không bao giờ&#10;sửa được (đã từng gặp false-positive thật)." style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;arcSize=6;fillColor=#F6C9D9;strokeColor=#C94D7A;" vertex="1" parent="1"><mxGeometry x="1600" y="640" width="340" height="210" as="geometry" /></mxCell><mxCell id="e_in_1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="input" target="step1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_1_2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="step1" target="step2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_2_3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="step2" target="step3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_3_4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="step3" target="step4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_mem_2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#B08900;strokeColor=#B08900;" edge="1" parent="1" source="mem_box" target="step2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_guard_2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#C94D4D;strokeColor=#C94D4D;" edge="1" parent="1" source="guard_box" target="step2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_guard_3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#C94D4D;strokeColor=#C94D4D;" edge="1" parent="1" source="guard_box" target="step3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_c1_c2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="c1" target="c2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_c2_c3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="c2" target="c3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_c3_c4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="c3" target="c4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_c4_c5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="c4" target="c5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_c5_c6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="c5" target="c6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_c6_hitl2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#C94D7A;strokeColor=#C94D7A;" edge="1" parent="1" source="c6" target="hitl2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1770" y="520" /></Array></mxGeometry></mxCell><mxCell id="e_hitl2_finished" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#6AA84F;strokeColor=#6AA84F;" edge="1" parent="1" source="hitl2" target="finished" value="Không"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1770" y="600" /></Array></mxGeometry></mxCell><mxCell id="e_hitl2_redo" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#C94D7A;strokeColor=#C94D7A;" edge="1" parent="1" source="hitl2" target="step3" value="Có — redo Bước 3+4 (tối đa 3 lần)"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1900" y="745" /><mxPoint x="1900" y="245" /></Array></mxGeometry></mxCell><mxCell id="e_1_hitl1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#C94D7A;strokeColor=#C94D7A;" edge="1" parent="1" source="step1" target="hitl1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_2_hitl1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#C94D7A;strokeColor=#C94D7A;" edge="1" parent="1" source="step2" target="hitl1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="700" y="490" /></Array></mxGeometry></mxCell><mxCell id="e_3_hitl1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#C94D7A;strokeColor=#C94D7A;" edge="1" parent="1" source="step3" target="hitl1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1410" y="380" /><mxPoint x="1410" y="400" /><mxPoint x="390" y="400" /></Array></mxGeometry></mxCell><mxCell id="e_hitl1_redo" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#C94D7A;strokeColor=#C94D7A;" edge="1" parent="1" source="hitl1" target="step2" value="Nhập feedback — chạy lại đúng stage đó"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="20" y="350" /><mxPoint x="20" y="245" /></Array></mxGeometry></mxCell></root></mxGraphModel></diagram></mxfile>