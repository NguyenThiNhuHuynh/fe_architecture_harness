<mxfile host="app.diagrams.net" version="24.0.0"><diagram name="User Flow + HITL" id="frontforge-userflow-hitl-v4"><mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1750" pageHeight="1750" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="u1" value="Người dùng nhập yêu cầu" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ECE7FB;strokeColor=#6D4DE0;" vertex="1" parent="1"><mxGeometry x="620" y="30" width="300" height="55" as="geometry" /></mxCell><mxCell id="u3" value="Run&#10;→ Orchestrator bắt đầu" style="rounded=8;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ECE7FB;strokeColor=#6D4DE0;" vertex="1" parent="1"><mxGeometry x="620" y="115" width="300" height="55" as="geometry" /></mxCell><mxCell id="u4" value="Orchestrator chọn stage kế tiếp" style="rounded=8;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ECE7FB;strokeColor=#6D4DE0;" vertex="1" parent="1"><mxGeometry x="620" y="200" width="300" height="55" as="geometry" /></mxCell><mxCell id="u5" value="Đọc context từ output,&#10;build prompt cho stage đó" style="rounded=8;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F1EDF9;strokeColor=#8B7BB8;" vertex="1" parent="1"><mxGeometry x="620" y="285" width="300" height="55" as="geometry" /></mxCell><mxCell id="u6" value="Gọi Claude CLI" style="rounded=8;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FBEDDA;strokeColor=#C97A1F;" vertex="1" parent="1"><mxGeometry x="620" y="370" width="300" height="55" as="geometry" /></mxCell><mxCell id="u7" value="Verify pass?&#10;Dựa vào expected results" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F1EDF9;strokeColor=#8B7BB8;" vertex="1" parent="1"><mxGeometry x="640" y="455" width="260" height="95" as="geometry" /></mxCell><mxCell id="u7no" value="Thử lại&#10;(đưa lỗi vào prompt, tối đa N lần)" style="rounded=8;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F1EDF9;strokeColor=#8B7BB8;" vertex="1" parent="1"><mxGeometry x="1040" y="445" width="280" height="60" as="geometry" /></mxCell><mxCell id="u7fail" value="Hết lượt → FAILED" style="rounded=8;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="1040" y="530" width="280" height="55" as="geometry" /></mxCell><mxCell id="uwait" value="Người dùng chờ,&#10;chạy `frontforge run` lại" style="rounded=8;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="1040" y="610" width="280" height="60" as="geometry" /></mxCell><mxCell id="u8" value="Lưu output, DONE" style="rounded=8;whiteSpace=wrap;html=1;fontSize=12;fillColor=#E6EDFD;strokeColor=#2E5FE0;" vertex="1" parent="1"><mxGeometry x="620" y="580" width="300" height="55" as="geometry" /></mxCell><mxCell id="u8b" value="Stage này là quality_review?" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ECE7FB;strokeColor=#6D4DE0;" vertex="1" parent="1"><mxGeometry x="610" y="665" width="320" height="100" as="geometry" /></mxCell><mxCell id="hitl1" value="HUMAN-IN-THE-LOOP 1&#10;Xem output của stage&#10;Tiếp tục sang stage tiếp theo?" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;arcSize=16;strokeWidth=2;fillColor=#FCE9A8;strokeColor=#B08900;" vertex="1" parent="1"><mxGeometry x="200" y="815" width="420" height="110" as="geometry" /></mxCell><mxCell id="dec_stop" value="Dừng để tự sửa output?" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FCE9A8;strokeColor=#B08900;" vertex="1" parent="1"><mxGeometry x="250" y="965" width="320" height="90" as="geometry" /></mxCell><mxCell id="pause1" value="Tạm dừng&#10;Người dùng tự sửa outputs/*.json&#10;rồi tự chạy `frontforge run` lại" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fontSize=12;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="640" y="970" width="340" height="80" as="geometry" /></mxCell><mxCell id="fb1" value="Nhập yêu cầu chỉnh sửa&#10;(feedback tự nhiên bằng lời)" style="shape=parallelogram;whiteSpace=wrap;html=1;fontSize=12;perimeter=parallelogramPerimeter;fillColor=#FCE9A8;strokeColor=#B08900;" vertex="1" parent="1"><mxGeometry x="200" y="1095" width="420" height="65" as="geometry" /></mxCell><mxCell id="fb2" value="mark_dirty(&quot;stage hiện tại&quot;)&#10;+ đưa yêu cầu vào context cho lần chạy lại" style="rounded=8;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ECE7FB;strokeColor=#6D4DE0;" vertex="1" parent="1"><mxGeometry x="200" y="1185" width="420" height="75" as="geometry" /></mxCell><mxCell id="hitl2" value="HUMAN-IN-THE-LOOP 2&#10;quality_review liệt kê issues&#10;(blocker / major / minor)&#10;Tự động chạy sửa lỗi codegen?" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;arcSize=16;strokeWidth=2;fillColor=#FCE9A8;strokeColor=#B08900;" vertex="1" parent="1"><mxGeometry x="1080" y="815" width="420" height="110" as="geometry" /></mxCell><mxCell id="autofix" value="mark_dirty(&quot;codegen&quot;)&#10;+ đưa issues vào verification_errors" style="rounded=8;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ECE7FB;strokeColor=#6D4DE0;" vertex="1" parent="1"><mxGeometry x="1080" y="965" width="420" height="60" as="geometry" /></mxCell><mxCell id="u10" value="Pipeline hoàn tất&#10;code thật trong generated/" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1"><mxGeometry x="620" y="1330" width="300" height="55" as="geometry" /></mxCell><mxCell id="u11" value="Người dùng xem code /&#10;chạy `frontforge status`" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ECE7FB;strokeColor=#6D4DE0;" vertex="1" parent="1"><mxGeometry x="620" y="1415" width="300" height="55" as="geometry" /></mxCell><mxCell id="s_mem" value="State / Memory&#10;• Trước build prompt: đọc seed.json +&#10;  outputs/&lt;tổ tiên&gt;.json làm context&#10;• Đầu mỗi lần chạy stage: ghi status=RUNNING&#10;• Khi DONE: ghi outputs/&lt;stage&gt;.json +&#10;  input_hash + duration_ms/cost_usd&#10;• Khi FAILED: ghi status=FAILED + error&#10;• Mỗi lần run_all() mới: so input_hash để&#10;  tự phát hiện cần chạy lại" style="rounded=10;whiteSpace=wrap;html=1;fontSize=10;dashed=1;align=left;spacingLeft=6;valign=top;fillColor=#E6EDFD;strokeColor=#2E5FE0;" vertex="1" parent="1"><mxGeometry x="20" y="170" width="400" height="190" as="geometry" /></mxCell><mxCell id="s_guard" value="Guardrails&#10;• Mọi lệnh gọi Claude: --json-schema ép đúng&#10;  cấu trúc Pydantic model&#10;• Chọn stage kế tiếp: DAG cố định, chỉ chạy&#10;  khi mọi dependency đã DONE&#10;• Đầu mỗi lần run: RunLock chặn 2 tiến trình&#10;  cùng ghi state.json&#10;• Vòng retry: max_retries=2 → tối đa 3 lần&#10;• Stage vừa FAILED không được chọn lại&#10;  trong cùng lượt chạy" style="rounded=10;whiteSpace=wrap;html=1;fontSize=10;dashed=1;align=left;spacingLeft=6;valign=top;fillColor=#FBEDDA;strokeColor=#C97A1F;" vertex="1" parent="1"><mxGeometry x="20" y="390" width="400" height="190" as="geometry" /></mxCell><mxCell id="s_sec" value="Security&#10;• --tools &quot;&quot; tắt hoàn toàn quyền gọi&#10;  tool/chạy lệnh của model&#10;• --no-session-persistence, không rò rỉ&#10;  ngữ cảnh giữa các lần gọi&#10;• safe_join() chặn path traversal khi ghi file&#10;• Chỉ FilesystemTool được ghi, giới hạn&#10;  trong generated/&#10;• [Chưa có] Quét nội dung nguy hiểm trước khi ghi" style="rounded=10;whiteSpace=wrap;html=1;fontSize=10;dashed=1;align=left;spacingLeft=6;valign=top;fillColor=#FBE2E5;strokeColor=#C94D5F;" vertex="1" parent="1"><mxGeometry x="20" y="610" width="400" height="190" as="geometry" /></mxCell><mxCell id="s_obs" value="Observability&#10;• logger.info(DONE) / warning(lỗi) — log text&#10;• EventLogger ghi 1 dòng JSON/sự kiện vào&#10;  .harness/logs/events-&lt;id&gt;.jsonl&#10;• Cuối run: bảng tổng kết thời gian,&#10;  chi phí, stage tốn nhất" style="rounded=10;whiteSpace=wrap;html=1;fontSize=10;dashed=1;align=left;spacingLeft=6;valign=top;fillColor=#DFF5EC;strokeColor=#1F9D75;" vertex="1" parent="1"><mxGeometry x="1400" y="500" width="320" height="160" as="geometry" /></mxCell><mxCell id="legend" value="Danh sách 11 stage (đúng thứ tự DAG)&#10;1. clarification&#10;2. requirement&#10;3. business_analysis&#10;4. design_system&#10;5. information_architecture&#10;6. frontend_architecture&#10;7. page_planning&#10;8. component_planning&#10;9. codegen&#10;10. preview&#10;11. quality_review" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;valign=top;spacing=8;fillColor=#3d2f5c;strokeColor=#6D4DE0;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="20" y="1330" width="400" height="260" as="geometry" /></mxCell><mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u1" target="u3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u3" target="u4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u4" target="u5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u5" target="u6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u6" target="u7"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e6y" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u7" target="u8" value="Có"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e6n" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u7" target="u7no" value="Không"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e7no_retry" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u7no" target="u5" value="lặp lại với lỗi vừa báo"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1370" y="313" /></Array></mxGeometry></mxCell><mxCell id="e7no_fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;" edge="1" parent="1" source="u7no" target="u7fail" value="vẫn không pass sau N lần"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e7fail_wait" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u7fail" target="uwait"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="ewait_u4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="uwait" target="u4" value="quay lại chọn stage&#10;(tự bỏ qua phần đã xong)"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1650" y="227" /></Array></mxGeometry></mxCell><mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u8" target="u8b"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e8b_no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#B08900;strokeColor=#B08900;" edge="1" parent="1" source="u8b" target="hitl1" value="Không (stage khác)"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="560" y="780" /></Array></mxGeometry></mxCell><mxCell id="e8b_yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#B08900;strokeColor=#B08900;" edge="1" parent="1" source="u8b" target="hitl2" value="Có (vừa xong QA)"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1290" y="780" /></Array></mxGeometry></mxCell><mxCell id="e_hitl1_yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#B08900;strokeColor=#B08900;" edge="1" parent="1" source="hitl1" target="u4" value="Có, tiếp tục"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="160" y="850" /><mxPoint x="160" y="227" /></Array></mxGeometry></mxCell><mxCell id="e_hitl1_no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#B08900;strokeColor=#B08900;" edge="1" parent="1" source="hitl1" target="dec_stop" value="Không"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_stop_yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#B08900;strokeColor=#B08900;" edge="1" parent="1" source="dec_stop" target="pause1" value="Có"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_stop_no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#B08900;strokeColor=#B08900;" edge="1" parent="1" source="dec_stop" target="fb1" value="Không"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_fb1_fb2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="fb1" target="fb2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_fb2_u4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#6D4DE0;strokeColor=#6D4DE0;" edge="1" parent="1" source="fb2" target="u4" value="chạy lại đúng stage này"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="120" y="1222" /><mxPoint x="120" y="227" /></Array></mxGeometry></mxCell><mxCell id="e_hitl2_yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#B08900;strokeColor=#B08900;" edge="1" parent="1" source="hitl2" target="autofix" value="Có"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e_autofix_u4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#6D4DE0;strokeColor=#6D4DE0;" edge="1" parent="1" source="autofix" target="u4" value="chạy lại từ codegen"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1720" y="995" /><mxPoint x="1720" y="227" /></Array></mxGeometry></mxCell><mxCell id="e_hitl2_no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#1F9D75;strokeColor=#1F9D75;" edge="1" parent="1" source="hitl2" target="u10" value="Không"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1290" y="1140" /><mxPoint x="1290" y="1357" /></Array></mxGeometry></mxCell><mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="u10" target="u11"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="es_mem" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#2E5FE0;strokeColor=#2E5FE0;startArrow=block;endArrow=block;" edge="1" parent="1" source="s_mem" target="u4" value="đọc / ghi"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="es_guard" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#C97A1F;strokeColor=#C97A1F;" edge="1" parent="1" source="s_guard" target="u6" value="RunLock + DAG"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="es_sec" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#C94D5F;strokeColor=#C94D5F;" edge="1" parent="1" source="s_sec" target="u6" value="tools rỗng"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="es_obs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;fontColor=#1F9D75;strokeColor=#1F9D75;" edge="1" parent="1" source="s_obs" target="u7fail" value="ghi log"><mxGeometry relative="1" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>